# Copy this to .env.local and fill in values
DATABASE_URL="file:./prisma/dev.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Optional: comma-separated admin email addresses
AUTH_ADMIN_EMAILS="admin@example.com"

# Optional: comma-separated whitelisted editor emails
AUTH_WHITELIST="editor@example.com,admin@example.com"

# Dev only: set to "true" to enable password bypass (NEVER in production)
# NEXT_PUBLIC_DEV_AUTH_BYPASS=true
